    sheet = ss.insertSheet('音声フォルダ要約');
    sheet.appendRow(['分類フォルダ', '対象日付', 'ファイル数', '主要ファイル名例', '備考']);
  }
  
  var data = [
    ['20251019_活動記録', '2025/10/19', 2, '20251019_122025_録音.mp3', '活動記録の録音'],
    ['20251116_長時間会議', '2025/11/16', 7, '20251116_115058_録音_編集済.mp4', '長時間の会議録音（分割セグメントあり）'],
